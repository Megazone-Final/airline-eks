nameOverride: svc-auth
namespace: svc-auth
component: backend

image:
  repository: 036333380579.dkr.ecr.ap-northeast-2.amazonaws.com/airline-backend/auth
  tag: latest
  pullPolicy: Always

service:
  name: http
  port: 8081
  targetPort: 8081

resources:
  limits:
    memory: "128Mi"
    cpu: "500m"
  requests:
    memory: "64Mi"
    cpu: "250m"

autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  averageUtilization: 60
  behavior:
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
      - type: Percent
        value: 50
        periodSeconds: 60
    scaleUp:
      stabilizationWindowSeconds: 60
      policies:
      - type: Percent
        value: 100
        periodSeconds: 60
      - type: Pods
        value: 2
        periodSeconds: 60
      selectPolicy: Max

config:
  SERVER_PORT: "8081"
  SPRING_PROFILES_ACTIVE: "prod"

  DB_HOST: "test-db.cb8q4mm6485z.ap-northeast-2.rds.amazonaws.com"
  DB_PORT: "3306"
  DB_NAME: "auth_db"
  LOG_LEVEL: "INFO"

probes:
  liveness:
    path: /health
    port: 8081
    initialDelaySeconds: 10
    periodSeconds: 5
    timeoutSeconds: 2
    failureThreshold: 3
  readiness:
    path: /health
    port: 8081
    initialDelaySeconds: 10
    periodSeconds: 5
    timeoutSeconds: 2
    failureThreshold: 3
